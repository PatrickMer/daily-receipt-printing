# Daily Receipt Printing - Environment Variables
# Copy this file to .env and fill in real values.

# Google Calendar private iCal URL
# Found in Google Calendar > Settings > [Your Calendar] > "Secret address in iCal format"
GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_CALENDAR_ID/private-XXXXXXXX/basic.ics
